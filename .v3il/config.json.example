{
    "system": {
        "listen_addr": "0.0.0.0",
        "listen_port": 8000,
        "jwt_signing_key": "replace-with-at-least-32-random-characters",
        "bootstrap_admin": {
            "enabled": true,
            "username": "admin",
            "email": "admin@v3il.local",
            "password": "replace-with-a-strong-password"
        }
    },
    "database": {
        "host": "127.0.0.1",
        "port": 5432,
        "database": "v3il",
        "username": "root",
        "password": "replace-with-a-strong-database-password",
        "pool_size": 32,
        "max_overflow": 32,
        "pool_timeout_seconds": 30,
        "pool_recycle_seconds": 1800,
        "pool_pre_ping": true
    },
    "agent_runtime": {
        "main_max_turns": 1000,
        "subordinate_max_turns": 1000,
        "model_stream_idle_timeout_seconds": 300,
        "report_retention_seconds": 259200,
        "context_compression_trigger_ratio": 0.9,
        "context_compression_hard_stop_ratio": 0.98,
        "context_compression_target_ratio": 0.2,
        "context_budget_model_call_ratio": 0.8,
        "context_compression_preserve_recent_ratio": 0.25,
        "context_compression_preserve_recent_items": 20,
        "context_compression_min_items": 12,
        "context_compression_summary_max_tokens": 8000
    },
    "agent_pool": {
        "max_size": 256,
        "ttl_seconds": 1800,
        "sweep_interval_seconds": 60
    },
    "behavior_capture": {
        "poll_interval_seconds": 1.0,
        "batch_size": 500,
        "max_batches_per_poll": 8,
        "concurrency": 16
    },
    "threat_automation": {
        "enabled": true,
        "correlation_window_seconds": 1800,
        "notification_event_limit": 200
    },
    "lightrag": {
        "embedding_api": "https://api.openai.com/v1",
        "embedding_key": "",
        "embedding_model": "text-embedding-3-small",
        "embedding_dim": 1536,
        "llm_api": "https://api.openai.com/v1",
        "llm_key": "",
        "llm_model": "gpt-5",
        "graph_matches": 5,
        "chunk_matches": 10
    },
    "agents": {
        "cso": {
            "code": "cso",
            "name": "V3il",
            "description": "Chief Security Officer",
            "base_url": "https://api.openai.com/v1",
            "api_key": "",
            "model": "gpt-5",
            "use_responses": false,
            "context_window": 400000
        },
        "cth": {
            "code": "cth",
            "name": "H4wk",
            "description": "Threat Investigation Engineer",
            "base_url": "https://api.openai.com/v1",
            "api_key": "",
            "model": "gpt-5",
            "use_responses": false,
            "context_window": 400000
        },
        "cde": {
